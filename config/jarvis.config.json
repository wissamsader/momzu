      "kokoroVoice": "af_heart",
      "kokoroVoiceFr": "ff_siwis",
      "voice": "Samantha",
      "voiceFr": "Amélie",
      "rate": 190
    },
    "stt": {
      "binary": "bin/whisper/whisper-cli",
      "model": "large-v3-turbo-q8_0",
      "language": "auto",
      "languages": [
        "en",
        "fr",
        "ar"
      ]
    }
  },
  "commandDeck": [
    {
      "id": "stop-task",
      "label": "■ STOP",
      "kind": "chat",
      "target": "stop"
    },
    {
      "id": "briefing",
      "label": "BRIEFING",
      "kind": "chat",
      "target": "Give me a quick spoken briefing: today's date and time, my open objectives, my pending reminders (flag anything due soon), and anything important from our recent conversations. Keep it short and conversational."
    },
    {
      "id": "screen",
      "label": "SCREEN",
      "kind": "chat",
      "target": "Use see_screen, Read the screenshot it returns, and tell me briefly what's on my screen right now."
    },
    {
      "id": "summarize-page",
      "label": "THIS PAGE",
      "kind": "chat",
      "target": "Use the chrome tool: run \"current\" then \"readpage\", and give me a short spoken summary of the page I'm looking at."
    },
    {
      "id": "clear-chat",
      "label": "CLEAR",
      "kind": "builtin",
      "target": "clear"
    },
    {
      "id": "mute",
      "label": "VOICE ON/OFF",
      "kind": "builtin",
      "target": "toggle-speak"
    }
  ],
  "theme": {
    "accent": "#c084fc",
    "accent2": "#7dd3fc",
    "bg": "#07060b"
  },
  "dictation": {
    "hotkey": "CommandOrControl+Shift+D",
    "mode": "clipboard"
  },
  "remote": {
    "enabled": true
  },
  "intent": {
    "rules": {
      "open_app": {
        "priority": 10,
        "patterns": [
          "^open\\s+([\\w\\s]+)$"
        ]
      },
      "action": {
        "priority": 9,
        "patterns": [
          "^(close|launch|start|stop|run|show|find|play|pause|send|create|delete|set|turn|navigate|go to|browse|search for|click|type|scroll)"
        ]
      },
      "search": {
        "priority": 8,
        "patterns": [
          "^(search|google|look up|find information about|what is|who is|how to|weather|news)"
        ]
      },
      "dictation": {
        "priority": 7,
        "patterns": [
          "^(start dictation|stop dictation|type this|write this|dictate)"
        ]
      },
      "system_query": {
        "priority": 5,
        "patterns": [
          "^(what time|what day|what date|how are you|status|uptime|cpu|memory|battery|system|hostname)"
        ]
      }
    }
  },
  "memory": {
    "enabled": true,
    "recallLimit": 5,
    "recentTurns": 10,
    "extractFacts": true,
    "retentionDays": 90
  },
  "redaction": {
    "enabled": true,
    "patterns": {
      "email": false,
      "creditCard": true,
      "apiKey": true,
      "phone": false,
      "ssn": true,
      "address": false,
      "ipv4": false
    }
  }
}