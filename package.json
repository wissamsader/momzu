{
  "name": "momzu",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "main": "dashboard/main.cjs",
  "description": "Personal voice-driven AI command center. 100% local voice, any model.",
  "license": "MIT",
  "homepage": "https://momzu.space",
  "repository": {
    "type": "git",
    "url": "https://github.com/wissamsader/momzu.git"
  },
  "scripts": {
    "orchestrator": "node orchestrator/server.js",
    "dashboard": "electron dashboard/main.cjs",
    "dev": "concurrently -k \"npm:orchestrator\" \"npm:dashboard\"",
    "start": "npm run dev",
    "build": "electron-builder --mac",
    "dist": "npm run build"
  },
  "build": {
    "appId": "com.momzu.app",
    "productName": "Momzu",
    "npmRebuild": false,
    "mac": {
      "icon": "build/icon.icns",
      "target": "dmg",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSSpeechRecognitionUsageDescription": "Momzu uses on-device speech recognition to transcribe your voice commands. Nothing leaves your Mac."
      }
    },
    "files": [
      "dashboard/**/*",
      "orchestrator/**/*",
      "config/**/*",
      "!config/state/**",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*",
          "!whisper/models/**",
          "!speech-recognizer*",
          "!control-watcher"
        ]
      }
    ],
    "asarUnpack": [
      "orchestrator/**/*",
      "dashboard/**/*",
      "config/**/*",
      "bin/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "better-sqlite3": "^12.11.1",
    "chrome-remote-interface": "^0.34.0",
    "dotenv": "^16.4.5",
    "koffi": "^3.1.0",
    "qrcode-generator": "^2.0.4",
    "three": "^0.170.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  }
}
